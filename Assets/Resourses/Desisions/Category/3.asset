  question: "\u0422\u0435\u0431\u0435 \u043D\u0443\u0436\u043D\u043E \u0431\u044B\u0441\u0442\u0440\u043E
    \u043E\u0441\u0432\u043E\u0438\u0442\u044C \u043D\u043E\u0432\u0443\u044E \u043E\u0431\u043B\u0430\u0441\u0442\u044C.
    \u041A\u0430\u043A \u0443\u0434\u043E\u0431\u043D\u0435\u0435?"
  choiceA:
    text: "\u0423\u0439\u0442\u0438 \u0432 \u0442\u0438\u0448\u0438\u043D\u0443 \u0438
      \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u0442\u044C\u0441\u044F \u0441\u0430\u043C\u043E\u043C\u0443"
    primary:
      stat: 4
      value: 2
    secondary:
      stat: 6
      value: 1
  choiceB:
    text: "\u041E\u0431\u0441\u0443\u0436\u0434\u0430\u0442\u044C \u0432\u0441\u043B\u0443\u0445,
      \u043B\u043E\u0432\u0438\u0442\u044C \u043E\u0431\u0440\u0430\u0442\u043D\u0443\u044E
      \u0441\u0432\u044F\u0437\u044C"
