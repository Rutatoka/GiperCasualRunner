      stat: 2
      value: 2
    secondary:
      stat: 5
      value: 1
  choiceB:
    text: "\u0411\u0435\u0440\u0443 \u043A\u0443\u0441\u043E\u043A \u0440\u0430\u0431\u043E\u0442\u044B
