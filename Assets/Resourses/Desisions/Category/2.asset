  question: "\u041E\u0431\u0449\u0438\u0439 \u043F\u0440\u043E\u0435\u043A\u0442
    \u0431\u0443\u043A\u0441\u0443\u0435\u0442. \u0422\u0432\u043E\u0438 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F?"
  choiceA:
    text: "\u0424\u0438\u043A\u0441\u0438\u0440\u0443\u044E \u0440\u0435\u0448\u0435\u043D\u0438\u0435,
      \u043D\u0430\u0437\u043D\u0430\u0447\u0430\u044E \u0440\u043E\u043B\u0438"
