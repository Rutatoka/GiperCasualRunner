      stat: 0
      value: 2
    secondary:
      stat: 4
      value: 1
  choiceB:
    text: "\u0412\u0441\u0442\u0440\u0435\u0447\u0430\u0442\u044C \u043B\u044E\u0434\u0435\u0439,
      \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u0442\u044C \u0438\u0445, \u0434\u0435\u0440\u0436\u0430\u0442\u044C
