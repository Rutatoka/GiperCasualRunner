    text: "\u041D\u0430\u0441\u0442\u0440\u043E\u0438\u0442\u044C \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0443,
      \u0431\u043E\u0442\u0430 \u0438\u043B\u0438 \u043C\u0430\u0440\u0448\u0440\u0443\u0442"
